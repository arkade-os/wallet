# Temporary: while @arkade-os/sdk and @arkade-os/boltz-swap are consumed from
# locally-built vendor/*.tgz (see scripts/prepare-arkade-sdk.js), the tarballs
# are rebuilt from source on each install and are not byte-reproducible, so
# their lockfile integrity is not stable. pnpm enables frozen-lockfile by
# default under CI, which would reject the freshly built tarballs; disable it.
# Remove this file once the SDK changes are published to npm.
frozen-lockfile=false
