{
  "version": 0,
  "name": "banco-asset-to-btc",
  "params": [
    { "name": "makerWP", "type": "pubkey" },
    { "name": "wantAmount", "type": "int" },
    { "name": "server", "type": "pubkey" },
    { "name": "user", "type": "pubkey" }
  ],
  "functions": {
    "fulfill": {
      "tapscript": { "signers": ["$server"] },
      "arkadeScript": {
        "asm": [
          0,
          "INSPECTOUTPUTVALUE",
          "$wantAmount",
          "GREATERTHANOREQUAL",
          "VERIFY",
          0,
          "INSPECTOUTPUTSCRIPTPUBKEY",
          1,
          "EQUALVERIFY",
          "$makerWP",
          "EQUAL"
        ]
      }
    },
    "cancel": {
      "tapscript": { "signers": ["$user", "$server"] }
    }
  }
}
