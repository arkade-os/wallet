# Arkade Wallet — Maestro workspace
#
# Copy to config.yaml and set WALLET_URL:
#   cp config.yaml.example config.yaml
#
# WALLET_URL is opened automatically via the open_wallet_url subflow (Chrome on Android).
# Flows use appId: com.android.chrome + -p android (not desktop Chromium).
#
# Studio: ./maestro/studio.sh
# CLI:    ./maestro/run.sh complete-tests/flows/...
# Scenarios: ./maestro/scripts/run-scenario.sh smoke|onboarding|...

flows:
  - flows/**
  - complete-tests/flows/**

platform:
  android:
    disableAnimations: false

# Parsed by run.sh / run-scenario.sh (not Maestro env):
env:
  WALLET_URL: "https://your-preview-or-production-wallet-url"
  WALLET_PASSWORD: ""
